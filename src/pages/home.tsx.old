  { name: "Beard Oil", price: "$32", image: "https://images.unsplash.com/photo-1626285861696-9f0bf5a49c6d?q=80&w=400&auto=format&fit=crop" },
  { name: "Sea Salt Spray", price: "$24", image: "https://images.unsplash.com/photo-1556229162-5c63ed9c4ffb?q=80&w=400&auto=format&fit=crop" },
